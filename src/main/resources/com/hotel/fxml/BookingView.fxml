<?xml version="1.0" encoding="UTF-8"?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>

<SplitPane dividerPositions="0.35" xmlns:fx="http://javafx.com/fxml"
           fx:controller="com.hotel.controller.BookingController"
           styleClass="tab-content">

    <!-- ── LEFT: FORM ──────────────────────────────────────── -->
    <VBox styleClass="form-panel" spacing="14">
        <Label text="New Booking" styleClass="section-title"/>

        <Label text="Select Customer" styleClass="field-label"/>
        <ComboBox fx:id="cmbCustomer" maxWidth="Infinity" promptText="Choose customer..." styleClass="dark-combo"/>

        <Label text="Select Room (Available)" styleClass="field-label"/>
        <ComboBox fx:id="cmbRoom" maxWidth="Infinity" promptText="Choose room..." styleClass="dark-combo"/>

        <Label text="Check-In Date" styleClass="field-label"/>
        <DatePicker fx:id="dpCheckIn" maxWidth="Infinity" styleClass="dark-field"/>

        <Label text="Check-Out Date" styleClass="field-label"/>
        <DatePicker fx:id="dpCheckOut" maxWidth="Infinity" styleClass="dark-field"/>

        <Label text="Number of Days (auto-computed)" styleClass="field-label"/>
        <TextField fx:id="txtNumDays" promptText="Auto-filled from dates" styleClass="dark-field" editable="false"/>

        <Region VBox.vgrow="ALWAYS"/>

        <Button text="✅ Confirm Booking"    onAction="#handleBook"
                styleClass="btn-primary" maxWidth="Infinity"/>
        <Button text="🚪 Checkout Selected"  onAction="#handleCheckout"
                styleClass="btn-warning" maxWidth="Infinity"/>
        <Button text="🔄 Refresh"            onAction="#handleRefresh"
                styleClass="btn-secondary" maxWidth="Infinity"/>
    </VBox>

    <!-- ── RIGHT: TABLE ────────────────────────────────────── -->
    <VBox styleClass="table-panel" spacing="10">
        <Label text="All Bookings" styleClass="section-title"/>

        <TableView fx:id="tblBookings" VBox.vgrow="ALWAYS" styleClass="dark-table">
            <columns>
                <TableColumn fx:id="colBookingId" text="ID"        prefWidth="55"/>
                <TableColumn fx:id="colCustomer"  text="Customer"  prefWidth="140"/>
                <TableColumn fx:id="colRoom"      text="Room #"    prefWidth="70"/>
                <TableColumn fx:id="colRoomType"  text="Type"      prefWidth="100"/>
                <TableColumn fx:id="colCheckIn"   text="Check In"  prefWidth="110"/>
                <TableColumn fx:id="colCheckOut"  text="Check Out" prefWidth="110"/>
                <TableColumn fx:id="colDays"      text="Days"      prefWidth="60"/>
                <TableColumn fx:id="colStatus"    text="Status"    prefWidth="110"/>
            </columns>
            <placeholder><Label text="No bookings found." styleClass="empty-label"/></placeholder>
        </TableView>
    </VBox>
</SplitPane>
